#!/bin/bash
# NAI Workbench — Custodian MCP HTTP installer
set -euo pipefail

SERVICE_NAME="custodian-mcp-http"
VENV_PYTHON="$HOME/.custodian-venv/bin/python3"
RAW_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
if [ -d "$HOME/projects/nai-workbench/custodian" ]; then
    WORKBENCH_ROOT="$HOME/projects/nai-workbench"
else
    WORKBENCH_ROOT="$RAW_ROOT"
fi

SERVER_SCRIPT="$WORKBENCH_ROOT/custodian/mcp_http_server.py"
TOKEN_SCRIPT="$WORKBENCH_ROOT/custodian/gen_mcp_token.sh"
OAUTH_BOOTSTRAP_SCRIPT="$WORKBENCH_ROOT/custodian/register_oauth_client.py"
REQUIREMENTS_FILE="$WORKBENCH_ROOT/custodian/requirements.txt"
UNIT_TEMPLATE="$WORKBENCH_ROOT/config/custodian-mcp-http.service"
UNIT_TARGET="$HOME/.config/systemd/user/${SERVICE_NAME}.service"

echo "=== NAI Workbench Custodian MCP HTTP Installer ==="
echo ""

echo "[1/5] Checking prerequisites..."
if [ ! -f "$VENV_PYTHON" ]; then
    echo "  ERROR: venv python not found at $VENV_PYTHON"
    echo "  Run: python3 -m venv ~/.custodian-venv"
    exit 1
fi
if [ ! -f "$SERVER_SCRIPT" ]; then
    echo "  ERROR: server script not found at $SERVER_SCRIPT"
    exit 1
fi
if [ ! -f "$TOKEN_SCRIPT" ]; then
    echo "  ERROR: token generator not found at $TOKEN_SCRIPT"
    exit 1
fi
if [ ! -f "$OAUTH_BOOTSTRAP_SCRIPT" ]; then
    echo "  ERROR: OAuth bootstrap script not found at $OAUTH_BOOTSTRAP_SCRIPT"
    exit 1
fi
if [ ! -f "$UNIT_TEMPLATE" ]; then
    echo "  ERROR: unit template not found at $UNIT_TEMPLATE"
    exit 1
fi
echo "  -> Python: $VENV_PYTHON"
echo "  -> Repo:   $WORKBENCH_ROOT"
echo ""

echo "[2/5] Installing Custodian Python dependencies..."
"$VENV_PYTHON" -m pip install -q -r "$REQUIREMENTS_FILE"
echo "  -> Requirements installed"
echo ""

echo "[3/5] Generating bearer token..."
TOKEN="$($TOKEN_SCRIPT)"
if [ -z "$TOKEN" ]; then
    echo "  ERROR: token generator returned an empty token"
    exit 1
fi
echo "  -> Token generated"
echo ""

echo "[4/5] Installing systemd user service..."
mkdir -p "$HOME/.config/systemd/user"
sed \
    -e "s|__WORKING_DIRECTORY__|$WORKBENCH_ROOT|g" \
    -e "s|__PYTHON__|$VENV_PYTHON|g" \
    -e "s|__SCRIPT__|$SERVER_SCRIPT|g" \
    -e "s|__TOKEN__|$TOKEN|g" \
    "$UNIT_TEMPLATE" > "$UNIT_TARGET"
echo "  -> $UNIT_TARGET"
echo ""

echo "[5/5] Enabling and starting service..."
systemctl --user daemon-reload
systemctl --user enable --now "$SERVICE_NAME"
sleep 2
systemctl --user status "$SERVICE_NAME" --no-pager
echo ""
OAUTH_OUTPUT="$($VENV_PYTHON "$OAUTH_BOOTSTRAP_SCRIPT" --name claude-desktop)"
echo "OAuth client bootstrap:"
echo "$OAUTH_OUTPUT"
echo ""
echo "Bearer token for Claude.ai connector:"
echo "$TOKEN"

loginctl enable-linger "$(whoami)" 2>/dev/null || true
